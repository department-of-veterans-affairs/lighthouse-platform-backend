<div class="vads-u-padding-y--5 documentation">
  <%= link_to "Sign out here", destroy_user_session_path, class: "usa-button", method: :delete %>

  <h2>
    <%= "#{@environments.count} Environments" %>
  </h2>
  <%= form_tag bulk_upload_admin_api_v0_environments_path, multipart: true do %>
    <%= file_field_tag 'file', required: true %>
    <%= submit_tag 'Upload Environment List' %>
  <% end %>
  <%= form_tag destroy_all_admin_api_v0_environments_path do %>
    <%= submit_tag 'Delete Environments', class: 'usa-button-red' %>
  <% end %>
  <% @environments.each do |environment| %>
    <p>
      <%= environment.to_json %>
    </p>
  <% end %>
  <h2>
    <%= "#{@apis.count} APIs" %>
  </h2>
  <%= form_tag bulk_upload_admin_api_v0_apis_path, multipart: true do %>
    <%= file_field_tag 'file', required: true %>
    <%= submit_tag 'Upload API List' %>
  <% end %>
  <%= form_tag destroy_all_admin_api_v0_apis_path do %>
    <%= submit_tag 'Delete APIs', class: 'usa-button-red' %>
  <% end %>
  <% @apis.each do |api| %>
    <p>
      <%= api.to_json %>
      <%= api.api_ref.to_json %>
    </p>
  <% end %>

  <h2>
    <%= "#{@users.count} users / consumers" %>
  </h2>
  <%= form_tag admin_api_v0_migrate_consumers_path(migrate: ':migrate') do %>
    <%= submit_tag 'Migrate Consumers' %>
  <% end %>
  <% @users.each do |user| %>
    <p>User</p>
    <p>
      <%= user.to_json %>
      <br />
      <p>Consumer</p> <%= user.consumer.to_json %>
      <br />
      <br />
      <%= "#{user.consumer.consumer_api_assignments.count} APIs available" %>
      <% user.consumer.consumer_api_assignments.map do |consumer_api_assignment| %>
        <div>ENV: <%= consumer_api_assignment.api_environment.environment.name %></div>
        <div>API: <%= consumer_api_assignment.api_environment.api.name %></div>
        <br />
      <% end %>
    </p>
    <hr>
  <% end %>
  <%= form_tag destroy_all_admin_api_v0_consumers_path do %>
    <%= submit_tag 'Delete Consumers', class: 'usa-button-red' %>
  <% end %>
</div>
