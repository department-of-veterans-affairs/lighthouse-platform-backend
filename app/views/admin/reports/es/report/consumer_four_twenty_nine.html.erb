<div class="vads-l-grid-container vads-u-padding-y--5">
  <% if @consumer_twenty_nine['hits']['hits'].present? %>
    <div id="header-halo">
      <h1 clas="vads-u-margin-top--0 vads-u-margin-bottom--2">Kong Consumer Name:</h1>
    </div>
    <h3><%= @consumer_twenty_nine['hits']['hits'].first['_source']['consumer']['username'] %></h3>
    <% @consumer_twenty_nine['hits']['hits'].each do |log| %>
      <%= render "log", log: log %>
      <br/>
    <% end %>
  <% else %>
    <h3>No 429's reported within the last 30 days.</h3>
  <% end %>
</div>